# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000

# Your deployed frontend URL (update after deploying to Vercel)
FRONTEND_URL=https://your-app-name.vercel.app

# ─── MongoDB Atlas ─────────────────────────────────────────────────────────────
# Get this from MongoDB Atlas → Connect → Drivers → copy the connection string
MONGO_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/bugtrack

# ─── JWT ───────────────────────────────────────────────────────────────────────
# Any long random string — never share this
JWT_SECRET=replace_with_a_very_long_random_string_at_least_32_chars

# ─── Google OAuth ──────────────────────────────────────────────────────────────
# From Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# ─── Gmail (for OTP + password reset emails) ───────────────────────────────────
# Use a Gmail App Password — NOT your real Gmail password
# Google Account → Security → 2-Step Verification → App Passwords
MAIL_USER=yourgmail@gmail.com
MAIL_PASS=your_16_char_app_password_no_spaces
MAIL_FROM=BugTrack <yourgmail@gmail.com>
